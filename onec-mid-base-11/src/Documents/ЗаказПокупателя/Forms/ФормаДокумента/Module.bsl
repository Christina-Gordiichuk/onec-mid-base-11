#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	// + Кристина 27.01.2026 Типовой механизм расчета отключен
	//ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество;
	// - Кристина 27.01.2026 Типовой механизм расчета отключен
	
	// + Кристина 27.01.2026 Добавлен новый механизм расчета с учетом скидки
	СуммаБезСкидки =  ТекущиеДанные.Цена * ТекущиеДанные.Количество;
	СуммаСкидки = СуммаБезСкидки * Объект.ДЗ_СогласованнаяСкидка / 100;
	ТекущиеДанные.Сумма =  СуммаБезСкидки - СуммаСкидки;
	// - Кристина 27.01.2026 Добавлен новый механизм расчета с учетом скидки
	
	РассчитатьСуммуДокумента();
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры

#Область ПодключаемыеКоманды

